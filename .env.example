# =========================
# 模型 API 配置
# =========================
# 支持两类：
# 1. openai：OpenAI 官方接口
# 2. openai_compatible：兼容 OpenAI 风格的第三方模型 API
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=openai

# -------------------------
# LLM 配置
# -------------------------
# 通用变量，优先级高于 OPENAI_* 兼容变量
LLM_API_KEY=
LLM_API_BASE=
LLM_MODEL=gpt-4.1-mini
LLM_TEMPERATURE=0.2
LLM_TIMEOUT=60
LLM_MAX_TOKENS=2048

# -------------------------
# Embedding 配置
# -------------------------
# 如果你用别家的聊天模型，但仍然想用 OpenAI embedding，可以只改上面的 LLM 配置。
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=
EMBEDDING_MODEL=text-embedding-3-small

# -------------------------
# OpenAI 兼容旧变量
# -------------------------
# 如果你不想使用通用变量，也可以继续使用下面这些兼容变量。
OPENAI_API_KEY=
OPENAI_API_BASE=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=0.2

# =========================
# 向量库配置
# =========================
CHROMA_COLLECTION_NAME=ai_kb_docs

# =========================
# 文本切分与检索参数
# =========================
CHUNK_SIZE=800
CHUNK_OVERLAP=100
TOP_K=4
MAX_HISTORY_TURNS=6
NO_ANSWER_MIN_SCORE=0.22

# =========================
# 应用运行配置
# =========================
LOG_LEVEL=INFO
API_HOST=127.0.0.1
API_PORT=8000
CORS_ORIGINS=*
